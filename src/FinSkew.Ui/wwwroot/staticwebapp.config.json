{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/_framework/*",
      "/_content/*",
      "/css/*",
      "/images/*",
      "/favicon.svg",
      "/icon-192.png"
    ]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "routes": [
    {
      "route": "/_framework/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/_content/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/css/*",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    },
    {
      "route": "/images/*",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    },
    {
      "route": "/favicon.svg",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    },
    {
      "route": "/icon-192.png",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    },
    {
      "route": "/index.html",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate"
      }
    },
    {
      "route": "/*",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate"
      }
    }
  ]
}
